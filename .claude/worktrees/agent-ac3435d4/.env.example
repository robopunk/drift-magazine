# Drift — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Anthropic API (required for research agent)
ANTHROPIC_API_KEY=sk-ant-api03-YOUR-KEY-HERE

# Supabase (required for database + admin UI)
SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
SUPABASE_SERVICE_KEY=eyJYOUR-SERVICE-ROLE-KEY   # Write access — keep secret
SUPABASE_ANON_KEY=eyJYOUR-ANON-KEY             # Read-only — safe for browser

# Optional: override research interval (default: 30 days)
# RESEARCH_INTERVAL_DAYS=30

# Optional: use Sonnet instead of Opus (80% cheaper, some quality tradeoff)
# CLAUDE_MODEL=claude-sonnet-4-20250514
